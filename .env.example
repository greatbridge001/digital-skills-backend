# ===== SMARTFUTURE BACKEND ENVIRONMENT VARIABLES =====
# Copy this file to .env and fill in your actual values.
# Never commit the .env file to GitHub.

# PayHero API Credentials
# Get these from your PayHero dashboard at https://payhero.co.ke
PAYHERO_USERNAME=your_payhero_username_here
PAYHERO_PASSWORD=your_payhero_password_here
PAYHERO_CHANNEL_ID=your_channel_id_here

# Callback URL — must be the public URL of this backend + /api/pay/callback
# After deploying to Render, replace with your actual Render URL
CALLBACK_URL=https://smartfuture-backend.onrender.com/api/pay/callback

# Frontend URL — used for CORS. Set this to your Vercel URL after deployment.
FRONTEND_URL=https://your-project-name.vercel.app

# Server port — Render sets this automatically, leave as 4000 for local development
PORT=4000

# Admin panel password — change this to something secure before going live
ADMIN_PASSWORD=smartfuture2024

# ===== HOW TO CHANGE THE COURSE PRICE =====
# Option 1 (recommended): Log into the admin panel at /admin.html
#   and update the price from the Settings tab.
# Option 2: After changing the PAYHERO amount in the payment route (routes/pay.js),
#   update store.settings.price default in data/store.js.
